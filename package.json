{
  "name": "@jserxiao/xcli",
  "version": "1.0.3",
  "description": "A pluggable CLI tool for scaffolding TypeScript projects",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xcli": "dist/index.js"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "start": "node dist/index.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "cli",
    "typescript",
    "scaffold",
    "generator"
  ],
  "author": "jserxiao",
  "license": "MIT",
  "access": "public",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ejs": "^3.1.9",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.15",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.3",
    "vitepress": "^1.6.4"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "volta": {
    "node": "20.11.0"
  }
}
